        "## Simulate and compute payoffs"
      ]
    },
    {
      "cell_type": "code",
      "metadata": {
        "id": "simulate-cell"
      },
      "source": [
        "shots = 1024\n",
        "counts, alice_avg, bob_avg = simulate_and_compute_payoffs(qpd_q_q, shots=shots)\n",
        "print('Measurement counts:', counts)\n",
        "print(f'Average Payoff for Alice: {alice_avg:.2f}')\n",
        "print(f'Average Payoff for Bob:   {bob_avg:.2f}')"
      ],
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "metadata": {
        "id": "plot-cell"
      },
      "source": [
        "plot_payoffs(alice_avg, bob_avg)\n",
        "\n",
        "# Also show measurement histogram\n",
        "plot_histogram(counts)"
